[package]
name = "cvkg-render-web"
version.workspace = true
license.workspace = true
repository.workspace = true
description.workspace = true
edition = "2021"

[lib]
crate-type = ["cdylib", "rlib"]

[dependencies]
wgpu = { workspace = true, features = ["webgpu"] }
wasm-bindgen = { workspace = true }
wasm-bindgen-futures = { workspace = true }
js-sys = { workspace = true }
getrandom = { workspace = true }
log = { workspace = true }
console_log = "1.0"
bytemuck = { workspace = true }
web-sys = { workspace = true, features = [
    "Document",
    "Window",
    "Performance",
    "HtmlCanvasElement",
    "HtmlElement",
    "HtmlDivElement",
    "CssStyleDeclaration",
    "Location",
    "CanvasRenderingContext2d",
    "CanvasGradient",
    "CanvasPattern",
    "Element",
    "Node",
    "TextMetrics",
    "Response",
    "Headers",
    "Request",
    "RequestInit",
    "RequestMode",
    "WebSocket",
    "BinaryType",
    "MessageEvent",
    "CloseEvent",
    "ErrorEvent",
    "PointerEvent",
    "KeyboardEvent",
    "WebGl2RenderingContext",
    "Gpu",
    "GpuAdapter",
    "GpuDevice",
    "GpuCanvasContext",
    "GpuTextureFormat",
    "GpuCanvasConfiguration",
    "DomRect"
] }
cvkg-core = { workspace = true }
cvkg-vdom = { workspace = true }
serde = { workspace = true }
serde_json = { workspace = true }
# Lock-free RCU for image/texture cache; arc-swap is wasm32-compatible (no pthreads)
arc-swap = { workspace = true }

[features]
webgpu = []
default = ["webgpu"]

[build-dependencies]
naga = { workspace = true, features = ["wgsl-in", "spv-out"] }
