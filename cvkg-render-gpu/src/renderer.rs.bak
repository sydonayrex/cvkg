//! The main GpuRenderer struct and core frame lifecycle.
//!
//! This file has been decomposed into submodules for maintainability:
//! - `renderer/mod.rs` — Type definitions, GpuRenderer struct, helper types, pipeline cache
//! - `renderer/init.rs` — Constructor, configuration, cache management, utility methods
//! - `renderer/frame.rs` — Frame lifecycle (begin_frame, end_frame, draw methods)
//! - `renderer/render.rs` — Render submission, SVG loading, effects
//! - `renderer/capture.rs` — Frame capture and utility methods
//! - `renderer/tests.rs` — All test modules
//!
//! `GpuRenderer` is re-exported below for backward compatibility.

// Type aliases for backward compatibility
pub type SurtrRenderer = GpuRenderer;
pub type SurtrConfig = RendererConfig;

// Re-export the primary type for backward compatibility
pub use renderer::GpuRenderer;
