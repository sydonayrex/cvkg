[package]
name = "cvkg-render-native"
version.workspace = true
license.workspace = true
repository.workspace = true
description.workspace = true
edition.workspace = true

[dependencies]
cvkg-core = { workspace = true }
runic-text = { workspace = true }
winit = "0.30"
accesskit = "0.22"
accesskit_winit = "0.30"
log = { workspace = true }
cvkg-render-gpu = { workspace = true }
cvkg-vdom = { workspace = true }
tokio = { workspace = true, features = ["rt-multi-thread"] }
# Lock-free RCU for image/texture cache (replaces RwLock in Phase 4)
arc-swap = { workspace = true }
libc = { workspace = true }
image = { workspace = true }
pollster = "0.4.0"
